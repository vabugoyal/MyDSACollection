Calculating factorial 
    // Recursive template for N >= 0
    template<int N, typename = std::enable_if_t<(N >= 0)>>
    struct Factorial {
        static constexpr int value = N * Factorial<N-1>::value;
    };
    
    // Base case specialization
    template<>
    struct Factorial<0> {
        static constexpr int value = 1;
    };
    
    
